# Application
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000

# ── Local dev ─────────────────────────────────────────────────
# Prisma reads DATABASE_URL directly when running outside Docker
DATABASE_URL="postgresql://torbibi_user:torbibi_password@localhost:5432/torbibi_db?schema=public"

# ── Docker Compose ─────────────────────────────────────────────
# docker-compose.yml reads these and assembles DATABASE_URL for containers.
# You only need to set these when running via docker compose.
DB_NAME=torbibi_db
DB_USER=torbibi_user
DB_PASSWORD=torbibi_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key
JWT_REFRESH_EXPIRES_IN=30d

# OTP
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6

# SMS Provider - Primary: Arkesel, Fallback: Hubtel
SMS_PROVIDER=hubtel

# Arkesel SMS
ARKESEL_API_KEY=your-arkesel-api-key
ARKESEL_SENDER_ID=TORBIBI

# Hubtel SMS (fallback)
HUBTEL_CLIENT_ID=your-hubtel-client-id
HUBTEL_CLIENT_SECRET=your-hubtel-client-secret
HUBTEL_SENDER_ID=TORBIBI
HUBTEL_BASE_URL=https://smsc.hubtel.com/v1/messages

# Paystack
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
PAYSTACK_WEBHOOK_SECRET=your-paystack-webhook-secret

# ── Cloudinary (image storage) ─────────────────────────────────
# Get these from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Platform Commission ────────────────────────────────────────
# Percentage of each payment the platform retains (0.05 = 5%).
# The remainder (1 - rate) is paid out to the shop owner.
# Configurable without a code deploy — just update this value.
PLATFORM_COMMISSION_RATE=0.05

# Rate Limiting
OTP_RATE_LIMIT_WINDOW_MS=900000
OTP_RATE_LIMIT_MAX=5
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=100

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Logging
LOG_LEVEL=debug
LOG_DIR=./logs
