generator client {
  provider      = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  customer
  shop_owner
  admin
}

enum OtpType {
  login
  register
  reset
}

enum ShopStatus {
  active
  inactive
  suspended
}

enum ProductStatus {
  active
  draft
  archived
}

enum OrderStatus {
  pending
  confirmed
  processing
  shipped
  delivered
  cancelled
  refunded
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  cancelled
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(uuid())
  phone           String    @unique
  name            String?
  email           String?   @unique
  role            UserRole  @default(customer)
  isPhoneVerified Boolean   @default(false) @map("is_phone_verified")
  isActive        Boolean   @default(true)  @map("is_active")
  lastLoginAt     DateTime? @map("last_login_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt      @map("updated_at")

  shops  Shop[]
  orders Order[]

  @@map("users")
}

model Otp {
  id        String   @id @default(uuid())
  phone     String
  code      String
  type      OtpType
  expiresAt DateTime @map("expires_at")
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([phone, type])
  @@index([expiresAt])
  @@map("otps")
}

model Shop {
  id             String     @id @default(uuid())
  ownerId        String     @map("owner_id")
  name           String
  slug           String     @unique
  description    String?
  logoUrl        String?    @map("logo_url")
  logoPublicId   String?    @map("logo_public_id")
  bannerUrl      String?    @map("banner_url")
  bannerPublicId String?    @map("banner_public_id")
  brandColor     String?    @map("brand_color")   // Hex color e.g. "#F59E0B"
  phone          String
  email          String?
  address        Json?
  status         ShopStatus @default(active)
  currency       String     @default("GHS")
  // Paystack subaccount code (ACCT_xxx) — set once when shop registers payout account.
  // Passed on every transaction so Paystack auto-splits payment to shop at point of sale.
  subaccountCode      String? @map("subaccount_code")
  payoutType          String? @map("payout_type")
  payoutAccountName   String? @map("payout_account_name")
  payoutAccountNumber String? @map("payout_account_number")
  payoutBankCode      String? @map("payout_bank_code")
  // Subscription billing
  subscriptionStatus  SubscriptionStatus @default(trialing) @map("subscription_status")
  trialEndsAt         DateTime?          @map("trial_ends_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt      @map("updated_at")

  owner        User              @relation(fields: [ownerId], references: [id])
  products     Product[]
  orders       Order[]
  payments     Payment[]
  orderCounter OrderCounter?
  subscription ShopSubscription?

  @@index([ownerId])
  @@index([status])
  @@map("shops")
}

model Product {
  id             String        @id @default(uuid())
  shopId         String        @map("shop_id")
  name           String
  slug           String
  description    String?
  price          Int
  compareAtPrice Int?          @map("compare_at_price")
  sku            String?
  quantity       Int           @default(0)
  trackInventory Boolean       @default(false) @map("track_inventory")
  images         Json          @default("[]")
  categoryId     String?       @map("category_id")
  tags           String[]      @default([])
  status         ProductStatus @default(draft)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt      @map("updated_at")

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, slug])
  @@index([shopId])
  @@index([shopId, status])
  @@index([shopId, createdAt(sort: Desc)])
  @@map("products")
}

model Order {
  id               String        @id @default(uuid())
  orderNumber      String        @unique @map("order_number")
  shopId           String        @map("shop_id")
  customerId       String        @map("customer_id")
  customerPhone    String        @map("customer_phone")
  items            Json
  subtotal         Int
  deliveryFee      Int           @default(0) @map("delivery_fee")
  total            Int
  status           OrderStatus   @default(pending)
  paymentStatus    PaymentStatus @default(pending) @map("payment_status")
  paymentReference String?       @map("payment_reference")
  shippingAddress  Json          @map("shipping_address")
  notes            String?
  cancelReason     String?       @map("cancel_reason")
  deliveryInfo     Json?         @map("delivery_info")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt      @map("updated_at")

  shop     Shop      @relation(fields: [shopId], references: [id])
  customer User      @relation(fields: [customerId], references: [id])
  payments Payment[]

  @@index([shopId])
  @@index([shopId, status])
  @@index([shopId, createdAt(sort: Desc)])
  @@index([customerId])
  @@index([paymentReference])
  @@map("orders")
}

model Payment {
  id        String        @id @default(uuid())
  orderId   String        @map("order_id")
  shopId    String        @map("shop_id")
  amount    Int
  currency  String        @default("GHS")
  provider  String        @default("paystack")
  reference String        @unique
  status    PaymentStatus @default(pending)
  channel   String?
  metadata  Json?
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt      @map("updated_at")

  order Order @relation(fields: [orderId], references: [id])
  shop  Shop  @relation(fields: [shopId], references: [id])

  @@index([orderId])
  @@index([shopId])
  @@map("payments")
}

// Shop subscription — one active subscription per shop.
// Created/updated via Paystack webhook events (subscription.create, invoice.payment_success, etc.)
model ShopSubscription {
  id                       String             @id @default(uuid())
  shopId                   String             @unique @map("shop_id")
  paystackPlanCode         String             @map("paystack_plan_code")
  paystackSubscriptionCode String?            @map("paystack_subscription_code")
  paystackCustomerCode     String?            @map("paystack_customer_code")
  paystackEmailToken       String?            @map("paystack_email_token")
  status                   SubscriptionStatus @default(trialing)
  currentPeriodStart       DateTime?          @map("current_period_start")
  currentPeriodEnd         DateTime?          @map("current_period_end")
  cancelledAt              DateTime?          @map("cancelled_at")
  createdAt                DateTime           @default(now()) @map("created_at")
  updatedAt                DateTime           @updatedAt @map("updated_at")

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("shop_subscriptions")
}

// Atomic per-shop order number counter.
model OrderCounter {
  shopId  String @id @map("shop_id")
  counter Int    @default(0)

  shop Shop @relation(fields: [shopId], references: [id])

  @@map("order_counters")
}
